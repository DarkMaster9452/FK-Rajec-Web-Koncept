// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ──────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  COACH
  PLAYER
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  EXCUSED
}

enum MatchResult {
  WIN
  DRAW
  LOSS
}

// ── NextAuth required tables ───────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Core models ────────────────────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  emailVerified  DateTime?
  image          String?
  password       String?
  role           Role      @default(PLAYER)
  position       String?
  jerseyNumber   Int?
  dateOfBirth    DateTime?
  bio            String?   @db.Text
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  trainingsCreated Training[] @relation("CreatedBy")
  attendance     Attendance[]
  newsArticles   NewsArticle[]
  notifications  Notification[]
}

model Training {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  date        DateTime
  location    String
  duration    Int      @default(90) // minutes
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdById String
  createdBy   User   @relation("CreatedBy", fields: [createdById], references: [id])

  attendance  Attendance[]
  notifications Notification[]
}

model Attendance {
  id          String           @id @default(cuid())
  status      AttendanceStatus @default(ABSENT)
  note        String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  trainingId  String
  training    Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([trainingId, userId])
}

model NewsArticle {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String   @db.Text
  imageUrl    String?
  published   Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  authorId    String
  author      User   @relation(fields: [authorId], references: [id])
}

model Fixture {
  id          String    @id @default(cuid())
  homeTeam    String
  awayTeam    String
  date        DateTime
  venue       String?
  competition String?
  isHome      Boolean   @default(true)
  createdAt   DateTime  @default(now())

  result      Result?
}

model Result {
  id         String      @id @default(cuid())
  homeScore  Int
  awayScore  Int
  outcome    MatchResult
  notes      String?
  createdAt  DateTime    @default(now())

  fixtureId  String   @unique
  fixture    Fixture  @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
}

model StandingRow {
  id          String @id @default(cuid())
  team        String
  competition String
  played      Int    @default(0)
  won         Int    @default(0)
  drawn       Int    @default(0)
  lost        Int    @default(0)
  goalsFor    Int    @default(0)
  goalsAgainst Int   @default(0)
  points      Int    @default(0)
  position    Int    @default(1)
  isFkRajec   Boolean @default(false)
}

model Notification {
  id         String   @id @default(cuid())
  message    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  trainingId String?
  training   Training? @relation(fields: [trainingId], references: [id], onDelete: SetNull)
}
